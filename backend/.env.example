# Application
NODE_ENV=development
PORT=4000

# PostgreSQL (use DATABASE_URL or individual fields)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attendance_portal
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=attendance_portal
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false

# CORS — comma-separated origins (no spaces), e.g. http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookies (signed cookies if used)
COOKIE_SECRET=change-me-to-a-long-random-string-in-production

# Session (HttpOnly cookie + DB row; sliding idle timeout)
SESSION_COOKIE_NAME=session_token
SESSION_IDLE_MS=900000

# Attendance — calendar "today" and default timesheet month (IANA). India (Pune): Asia/Kolkata
ATTENDANCE_TIMEZONE=Asia/Kolkata

# Rate limiting (global API)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
